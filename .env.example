DATABASE_URL=postgres://postgres:postgres@postgres:5432/miden_bridge
BRIDGE_PROFILE=sepolia
BRIDGE_DEMO_ENABLED=1
BRIDGE_UI_ENABLED=1
BRIDGE_CORS_ALLOW_ORIGIN=*

MIDEN_RPC_URL=https://rpc.testnet.miden.io
MIDEN_REMOTE_PROVER_URL=
MIDEN_REMOTE_PROVER_TIMEOUT_SECS=180
MIDEN_MASTER_SEED_HEX=replace-with-32-byte-hex-seed
MIDEN_STORE_DIR=/var/lib/bridge/miden-store

EVM_RPC_URL=https://gateway.tenderly.co/public/sepolia
MASTER_MNEMONIC=replace-with-builder-controlled-test-mnemonic
# Solver key must hold Sepolia ETH for mock Miden -> Sepolia releases/refunds
# plus gas. Testnet key only.
SOLVER_PRIVATE_KEY=replace-with-funded-sepolia-solver-key
EVM_CHAIN_ID=11155111
EVM_TOKEN_ADDRESSES_PATH=/state/token-addresses.json
EVM_REQUIRED_CONFIRMATIONS=2
# Empty means Sepolia does not scan chain history. Demo flows submit the tx hash
# into the lifecycle immediately after sending the Sepolia deposit transaction.
EVM_DEPOSIT_SCAN_LOOKBACK_BLOCKS=
DEMO_EVM_FUNDED_PRIVATE_KEY=replace-with-funded-sepolia-user-key

# AggLayer Bali/Sepolia testnet helper defaults. Recheck against
# 0xMiden/miden-client#2173 bali-l2-withdraw.sh before funded withdrawals.
AGGLAYER_BRIDGE_ADDRESS=0x1348947e282138d8f377b467f7d9c2eb0f335d1f
AGGLAYER_DEST_NETWORK=76
AGGLAYER_DEST_L1_NETWORK=0
AGGLAYER_L2_CHAIN_ID=1022211914
AGGLAYER_MIDEN_BRIDGE_ID=mcst1arychvrurzxdy5qwz0mg5p5umsvsepyx
AGGLAYER_MIDEN_FAUCET_ID=mcst1arnrhfau9svl7cpu2tr8lfzzd5j87wwe
AGGLAYER_BRIDGE_SERVICE_API=https://miden-testnet-bridge.dev.eu-north-3.gateway.fm/api
AGGLAYER_MIDEN_NODE_URL=https://rpc.testnet.miden.io:443
AGGLAYER_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
AGGLAYER_GAS_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
AGGLAYER_GAS_LIMIT=300000
AGGLAYER_FORCE_UPDATE_GLOBAL_EXIT_ROOT=true

BRIDGE_HTTP_PORT=8080
LAB_UI_HTTP_PORT=3000
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
BRIDGE_PRICER=mock
RUST_LOG=info,sqlx=warn,hyper=warn,tower_http=warn
LOG_FORMAT=json
