# Legacy/local Anvil example. The default builder guide uses
# .env.sepolia.example plus compose.sepolia.yaml.
DATABASE_URL=postgres://postgres:postgres@postgres:5432/miden_bridge
BRIDGE_PROFILE=anvil
BRIDGE_DEMO_ENABLED=1
BRIDGE_UI_ENABLED=1
BRIDGE_CORS_ALLOW_ORIGIN=*
# Defaults to Miden public testnet. For local-node mode override to http://miden-node:57291; see README.
MIDEN_RPC_URL=https://rpc.testnet.miden.io
# Optional. Miden testnet/devnet RPCs use the native miden-client remote prover endpoint automatically.
MIDEN_REMOTE_PROVER_URL=
MIDEN_REMOTE_PROVER_TIMEOUT_SECS=180
# Replace before public testnet use. Generate with: openssl rand -hex 32
MIDEN_MASTER_SEED_HEX=replace-with-32-byte-hex-seed
# Compose container URL. For host-only cargo tests against Anvil, set EVM_RPC_URL=http://localhost:8545 in the shell.
EVM_RPC_URL=http://anvil:8545
MASTER_MNEMONIC=abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about
SOLVER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945382dbb7d2745078b2336b91c60d50d6b6d7
EVM_CHAIN_ID=271828
EVM_TOKEN_ADDRESSES_PATH=/state/token-addresses.json
EVM_REQUIRED_CONFIRMATIONS=1
EVM_DEPOSIT_SCAN_LOOKBACK_BLOCKS=
DEMO_EVM_FUNDED_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
BRIDGE_HTTP_PORT=8080
RUST_LOG=info
LOG_FORMAT=json
BRIDGE_PRICER=mock
